# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# MUST be service_role (secret) — NOT anon/public key (admin create user fails with "User not allowed")
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here
SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional: CORS (same-server setup uses * by default)
CORS_ORIGINS=*

# Server port (optional, start.ps1 uses 8000)
# PORT=8000

# Google Gemini (AI chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Legacy (no longer used — kept for reference)
# DB_HOST=localhost
# SECRET_KEY=
